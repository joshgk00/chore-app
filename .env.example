# Required: The public HTTPS origin for the app
PUBLIC_ORIGIN=https://chores.example.com

# Server port (default: 3000)
PORT=3000

# Household timezone (default: America/New_York)
TZ=America/New_York

# Required: Admin PIN for first boot (minimum 6 digits — choose your own)
# After first boot, change via the admin settings UI
INITIAL_ADMIN_PIN=

# API key for AI image generation (optional)
# IMAGE_GEN_API_KEY=

# Activity log retention in days (default: 365)
ACTIVITY_RETENTION_DAYS_DEFAULT=365

# Data directory inside the container (default: /data)
DATA_DIR=/data
