# ─── Required ────────────────────────────────────────────────────────────────

# Canonical HTTPS origin of the app — used by the service worker, manifest,
# Web Push setup, and secure cookie domain. Must match the URL you actually
# access the app from (e.g. behind a Cloudflare Tunnel).
PUBLIC_ORIGIN=https://chores.your-domain.com

# PIN used only on first boot to initialise the admin account.
# Once the admin PIN has been stored in the database this value is ignored.
# Must be at least 6 digits. Change before running for the first time.
INITIAL_ADMIN_PIN=change-me-before-first-boot

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# Port the Express server listens on inside the container.
PORT=3000

# Household timezone — used for time-slot windows, streak logic, and local-date
# calculations. Initialises the in-app timezone setting on first run only.
# Any IANA zone name is valid (e.g. America/Chicago, Europe/London).
TZ=America/New_York

# Directory where SQLite, uploaded assets, VAPID secrets, and backup bundles
# are persisted. Should be backed by a named Docker volume in production.
DATA_DIR=/data

# Number of days to retain activity-log rows. Canonical history and the points
# ledger are never purged. Initialises the in-app setting on first run only.
ACTIVITY_RETENTION_DAYS_DEFAULT=365

# ─── AI Image Generation (optional) ─────────────────────────────────────────

# API key for PPQ.ai image generation. Leave blank to disable AI image
# generation — manual image upload remains fully available as a fallback.
IMAGE_GEN_API_KEY=
